# Streamlit secrets template — copy to secrets.toml and fill in.
# secrets.toml MUST NOT be committed to git.
#
# Locally:  cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# On Streamlit Cloud: paste these values into the app's Secrets panel.

# --- Anthropic API (required for Jerry GPT) -----------------------------------
ANTHROPIC_API_KEY = "sk-ant-..."
JERRY_MODEL = "claude-opus-4-7"

# --- Auth cookie signing (required for session persistence) -------------------
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_SECRET = "change-me-to-a-long-random-string"

# --- Jerry GPT usage logging — Google Sheets backend (OPTIONAL) ---------------
# If this section is absent, Jerry GPT logs to stdout only (visible in Streamlit
# Cloud's "Manage app → Logs"). When configured, every query is also appended
# as a row to the specified Google Sheet.
#
# Setup steps:
#   1. Create a Google Sheet to receive logs. Note its ID from the URL:
#        https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
#   2. Go to https://console.cloud.google.com → create / pick a project.
#   3. Enable two APIs in that project:
#        - Google Sheets API
#        - Google Drive API
#   4. Create a service account: IAM & Admin → Service Accounts → Create.
#      Skip the optional role steps. After creation, open the service account
#      → Keys tab → Add Key → JSON. A .json file downloads.
#   5. Open the downloaded JSON. Copy every field into the `[gcp_service_account]`
#      table below. The private_key field has \n escapes — paste it as a
#      TOML triple-quoted string (see template below) so newlines stay intact.
#   6. Share the Google Sheet with the service account's `client_email`
#      (looks like xxx@<project>.iam.gserviceaccount.com) — give it Editor access.
#   7. Set JERRY_GPT_SHEET_ID below to the sheet ID from step 1.

# JERRY_GPT_SHEET_ID = "1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789ABCDEF"
# JERRY_GPT_SHEET_TAB = "queries"  # optional; defaults to "queries"

# [gcp_service_account]
# type = "service_account"
# project_id = "your-project-id"
# private_key_id = "abc123..."
# private_key = """-----BEGIN PRIVATE KEY-----
# MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQ...
# ...lots of base64...
# -----END PRIVATE KEY-----
# """
# client_email = "jerry-gpt-logger@your-project.iam.gserviceaccount.com"
# client_id = "123456789012345678901"
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/jerry-gpt-logger%40your-project.iam.gserviceaccount.com"
# universe_domain = "googleapis.com"
